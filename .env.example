# Apify API Token (required for live data fetching)
# Get yours at: https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here

# Optional: Revalidation interval in seconds (default: 3600 = 1 hour)
REVALIDATE_SECONDS=3600

# Optional: Number of news items per section (default: 5)
NEWS_PER_SECTION=5
